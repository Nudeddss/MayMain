local function _as_pickupBoxesWithRestock(StartPost)
    local gotBox = _as_pickupBoxes(StartPost)
    if not _as_checkAlive() or not AutoStocker.Enabled then return false end
    if not gotBox then
        local timeSinceRestock = tick() - AutoStocker._lastRestockTime
        if timeSinceRestock >= AutoStocker._RESTOCK_INTERVAL or AutoStocker._lastRestockTime == 0 then
            if not _as_restockGoldenBox() then return false end
            gotBox = _as_pickupBoxes(StartPost)
            if not gotBox then return false end
        else return false end
    end
    return true
end

local function _as_processFirstShelf(shelvesFolder, Newpost1, Newpost2, ReturnPost)
    if not _as_checkAlive() or not AutoStocker.Enabled then return false, nil, nil, nil end
    local shelf, attachment = _as_getNextShelf(shelvesFolder)
    if not shelf or not attachment then return false, nil, nil, nil end
    local post = attachment.WorldPosition
    local currentCategory = _as_getCategory(attachment.WorldPosition.Z)
    local LastPost
    if currentCategory == 1 then
        _as_moveToPosition(Newpost1, 6, 5)
        if not _as_checkAlive() or not AutoStocker.Enabled then return false, nil, nil, nil end
        LastPost = Newpost1; task.wait(0.05)
        _as_moveToPosition(post, 4, 5)
        if not _as_checkAlive() or not AutoStocker.Enabled then return false, nil, nil, nil end
    elseif currentCategory == 2 then
        _as_moveToPosition(Newpost2, 4, 5)
        if not _as_checkAlive() or not AutoStocker.Enabled then return false, nil, nil, nil end
        LastPost = Newpost2; task.wait(0.35)
        _as_moveToPosition(post, 4, 5)
        if not _as_checkAlive() or not AutoStocker.Enabled then return false, nil, nil, nil end
    else
        LastPost = ReturnPost
        _as_moveToPosition(post, 4, 5)
        if not _as_checkAlive() or not AutoStocker.Enabled then return false, nil, nil, nil end
    end
    AutoStocker._stopSprint()
    for i = 1, 20 do
        if not _as_checkAlive() or not AutoStocker.Enabled then return false, LastPost, currentCategory, post end
        task.wait(0.5)
    end
    return true, LastPost, currentCategory, post
end

local function _as_processNextShelf(shelvesFolder, Newpost1, Newpost2, ReturnPost, prevCategory, prevPost, prevLastPost)
    if not _as_checkAlive() or not AutoStocker.Enabled then return false, nil, nil, nil end
    local shelf, attachment = _as_getNextShelf(shelvesFolder)
    if not shelf or not attachment then return false, nil, nil, nil end
    local post = attachment.WorldPosition
    local currentCategory = _as_getCategory(attachment.WorldPosition.Z)
    local LastPost = prevLastPost
    if currentCategory == prevCategory then
        _as_moveToPosition(post, 4, 5)
        if not _as_checkAlive() or not AutoStocker.Enabled then return false, nil, nil, nil end
    elseif currentCategory == 1 and prevCategory == 2 then
        _as_moveToPosition(Newpost2, 4, 5)
        if not _as_checkAlive() or not AutoStocker.Enabled then return false, nil, nil, nil end
        _as_moveToPosition(Newpost1, 6, 5)     
        if not _as_checkAlive() or not AutoStocker.Enabled then return false, nil, nil, nil end           
    elseif currentCategory == 2 and prevCategory == 1 then
        _as_moveToPosition(Newpost1, 4, 5)
        if not _as_checkAlive() or not AutoStocker.Enabled then return false, nil, nil, nil end
        _as_moveToPosition(Newpost2, 6, 5)      
        if not _as_checkAlive() or not AutoStocker.Enabled then return false, nil, nil, nil end            
    else
        if prevLastPost and prevLastPost ~= ReturnPost then
            _as_moveToPosition(prevLastPost, 4, 5)
            if not _as_checkAlive() or not AutoStocker.Enabled then return false, nil, nil, nil end
            task.wait(0.3)
        end
        _as_moveToPosition(ReturnPost, 5, 5)
        if not _as_checkAlive() or not AutoStocker.Enabled then return false, nil, nil, nil end
        task.wait(0.3)
        if currentCategory == 1 then
            _as_moveToPosition(Newpost1, 6, 5)
            if not _as_checkAlive() or not AutoStocker.Enabled then return false, nil, nil, nil end
            LastPost = Newpost1; task.wait(0.05)
            _as_moveToPosition(post, 4, 5)
            if not _as_checkAlive() or not AutoStocker.Enabled then return false, nil, nil, nil end
        elseif currentCategory == 2 then
            _as_moveToPosition(Newpost2, 4, 5)
            if not _as_checkAlive() or not AutoStocker.Enabled then return false, nil, nil, nil end
            LastPost = Newpost2; task.wait(0.35)
            _as_moveToPosition(post, 4, 5)
            if not _as_checkAlive() or not AutoStocker.Enabled then return false, nil, nil, nil end
        else
            LastPost = ReturnPost
            _as_moveToPosition(post, 4, 5)
            if not _as_checkAlive() or not AutoStocker.Enabled then return false, nil, nil, nil end
        end
    end
    AutoStocker._stopSprint()
    for i = 1, 20 do
        if not _as_checkAlive() or not AutoStocker.Enabled then return false, LastPost, currentCategory, post end
        task.wait(0.5)
    end
    return true, LastPost, currentCategory, post
end

-- ---- main loop ----
function AutoStocker._mainLoop()
    -- Destroy DoorSystem objects
    for _, descendant in pairs(workspace:GetDescendants()) do
        if descendant.Name == "DoorSystem" then pcall(function() descendant:Destroy() end) end
    end

    -- Resolve workspace folders
    local folder = workspace:FindFirstChild("Map")
    if not folder then Utils.Alert("AutoStocker", "alert-triangle", "Map not found!", 3); AutoStocker.Enabled = false; return end
    folder = folder:FindFirstChild("Tiles")
    if not folder then Utils.Alert("AutoStocker", "alert-triangle", "Tiles not found!", 3); AutoStocker.Enabled = false; return end
    folder = folder:FindFirstChild("GasStationTile")
    if not folder then Utils.Alert("AutoStocker", "alert-triangle", "GasStationTile not found!", 3); AutoStocker.Enabled = false; return end
    folder = folder:FindFirstChild("Quick11")
    if not folder then Utils.Alert("AutoStocker", "alert-triangle", "Quick11 not found!", 3); AutoStocker.Enabled = false; return end
    folder = folder:FindFirstChild("Interior")
    if not folder then Utils.Alert("AutoStocker", "alert-triangle", "Interior not found!", 3); AutoStocker.Enabled = false; return end

    local shelfJob = folder:FindFirstChild("ShelfStockingJob")
    if not shelfJob then Utils.Alert("AutoStocker", "alert-triangle", "ShelfStockingJob not found!", 3); AutoStocker.Enabled = false; return end
    local GoldenBoxPart = shelfJob:FindFirstChild("GoldenBox")
    if not GoldenBoxPart then Utils.Alert("AutoStocker", "alert-triangle", "GoldenBox not found!", 3); AutoStocker.Enabled = false; return end
    local shelvesFolder = shelfJob:FindFirstChild("Shelves")
    if not shelvesFolder then Utils.Alert("AutoStocker", "alert-triangle", "Shelves not found!", 3); AutoStocker.Enabled = false; return end

    local JobPost    = Vector3.new(165.800, 255.315, 202.809)
    local Newpost1   = Vector3.new(128.992, 255.315, 167.364)
    local Newpost2   = Vector3.new(128.872, 255.315, 184.629)
    local ReturnPost = Vector3.new(130.244, 255.315, 203.114)
    local StartPost  = Vector3.new(148.879, 255.315, 208.210)
    local NameJob    = "shelf_stocker"

    -- Join job if needed
    if not _as_hasJob(NameJob) then
        local joined = _as_tryJoinJob(JobPost, NameJob, 3)
        if not joined then
            AutoStocker._stopSprint()
            Utils.Alert("AutoStocker", "alert-triangle", "Gagal join job!", 3)
            AutoStocker.Enabled = false; return
        end
    end
    if not _as_hasJob(NameJob) then
        AutoStocker._stopSprint()
        Utils.Alert("AutoStocker", "alert-triangle", "Job tidak aktif!", 3)
        AutoStocker.Enabled = false; return
    end

    Utils.Alert("AutoStocker", "package", "Mulai auto stocking...", 3)

    -- Main loop
    while AutoStocker.Enabled do
        if not _as_checkAlive() then
            -- Wait for respawn
            task.wait(3)
            if not AutoStocker.Enabled then break end
            local ok = Utils.WaitForCharacter(LocalPlayer, 15)
            if not ok or not AutoStocker.Enabled then break end
            task.wait(1)
            continue
        end

        if not _as_hasJob(NameJob) then
            Utils.Alert("AutoStocker", "alert-triangle", "Job hilang, mencoba join ulang...", 3)
            local joined = _as_tryJoinJob(JobPost, NameJob, 3)
            if not joined then
                Utils.Alert("AutoStocker", "alert-triangle", "Gagal re-join job, berhenti.", 3)
                break
            end
        end

        local success = _as_pickupBoxesWithRestock(StartPost)
        if not AutoStocker.Enabled then break end

        if not success then
            AutoStocker._stopSprint()
            for j = 1, 60 do
                if not _as_checkAlive() or not AutoStocker.Enabled then break end
                task.wait(0.5)
            end
            continue
        end

        _as_moveToPosition(ReturnPost, 5, 5)
        if not _as_checkAlive() or not AutoStocker.Enabled then break end

        local LastPost, currentCategory, currentPost

        -- First shelf
        if _as_countBoxes() > 0 and _as_hasAvailableShelf(shelvesFolder) then
            local processed, newLP, newCat, newPost = _as_processFirstShelf(shelvesFolder, Newpost1, Newpost2, ReturnPost)
            if processed then
                LastPost = newLP; currentCategory = newCat; currentPost = newPost
            end
        end

        -- Next shelves
        while _as_countBoxes() > 0 and _as_hasAvailableShelf(shelvesFolder) do
            if not _as_checkAlive() or not AutoStocker.Enabled then break end
            local processed, newLP, newCat, newPost = _as_processNextShelf(shelvesFolder, Newpost1, Newpost2, ReturnPost, currentCategory, currentPost, LastPost)
            if not processed then break end
            LastPost = newLP; currentCategory = newCat; currentPost = newPost
        end

        if not _as_checkAlive() or not AutoStocker.Enabled then break end

        -- Return
        if LastPost and LastPost ~= ReturnPost then
            _as_moveToPosition(LastPost, 4, 5)
            if not _as_checkAlive() or not AutoStocker.Enabled then break end
            task.wait(0.3)
        end
        _as_moveToPosition(ReturnPost, 5, 5)
        if not _as_checkAlive() or not AutoStocker.Enabled then break end
        task.wait(0.3)
        _as_moveToPosition(StartPost, 5, 5)
        if not _as_checkAlive() or not AutoStocker.Enabled then break end
        AutoStocker._stopSprint(); task.wait(0.5)
    end

    AutoStocker._stopSprint()
    Utils.Alert("AutoStocker", "package", "Auto stocker berhenti.", 2)
end

-- ---- public API ----

function AutoStocker.Enable()
    if AutoStocker.Enabled then return end
    AutoStocker.Enabled = true
    AutoStocker._lastRestockTime = 0
    AutoStocker._thread = task.spawn(AutoStocker._mainLoop)
end

function AutoStocker.Disable()
    AutoStocker.Enabled = false
    AutoStocker._stopSprint()
end

function AutoStocker.Toggle(state)
    if state then AutoStocker.Enable() else AutoStocker.Disable() end
end


