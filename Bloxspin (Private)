        Freecam.CharOriginal.JumpHeight = hum.JumpHeight
        Freecam.CharOriginal.AutoRotate = hum.AutoRotate
        hum.WalkSpeed  = 0; hum.JumpPower  = 0; hum.JumpHeight = 0; hum.AutoRotate = false
    end
