        Freecam.CharOriginal.Anchored = hrp.Anchored
        hrp.Anchored = true
    end
end

function Freecam.UnfreezeCharacter()
    local char = LocalPlayer.Character; if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if hum and Freecam.CharOriginal.WalkSpeed then
        hum.WalkSpeed  = Freecam.CharOriginal.WalkSpeed
        hum.JumpPower  = Freecam.CharOriginal.JumpPower
        hum.JumpHeight = Freecam.CharOriginal.JumpHeight
        hum.AutoRotate = Freecam.CharOriginal.AutoRotate
    end
    if hrp and Freecam.CharOriginal.Anchored ~= nil then
        hrp.Anchored = Freecam.CharOriginal.Anchored
    end
    Freecam.CharOriginal = {}
end

function Freecam.Enable()
    if Freecam.Enabled then return end
    Freecam.Enabled       = true
    Freecam.MouseUnlocked = false
    local cam = workspace.CurrentCamera
    local uis = Services.UserInputService
    Freecam.Original.CameraType    = cam.CameraType
    Freecam.Original.CameraSubject = cam.CameraSubject
    Freecam.Original.MouseBehavior = uis.MouseBehavior
    Freecam.Original.MouseIcon     = uis.MouseIconEnabled
    cam.CameraType    = Enum.CameraType.Scriptable
    uis.MouseBehavior = Enum.MouseBehavior.LockCenter
    Freecam.FreezeCharacter()
    local lv    = cam.CFrame.LookVector
    local yaw   = math.atan2(-lv.X, -lv.Z)
    local pitch = math.asin(math.clamp(lv.Y, -1, 1))
    local sensitivity = 0.003
    local keysDown    = {}
    Freecam.Conns.inputBegan = uis.InputBegan:Connect(function(input, gpe)
        if not Freecam.Enabled then return end
        if input.UserInputType == Enum.UserInputType.MouseButton2 then
            Freecam.MouseUnlocked = not Freecam.MouseUnlocked
            if Freecam.MouseUnlocked then
                uis.MouseBehavior    = Enum.MouseBehavior.Default
                uis.MouseIconEnabled = true
            else
                uis.MouseBehavior    = Enum.MouseBehavior.LockCenter
                uis.MouseIconEnabled = false
            end
            return
        end
        if gpe then return end
        if input.KeyCode then keysDown[input.KeyCode] = true end
    end)
    Freecam.Conns.inputEnded = uis.InputEnded:Connect(function(input)
        if input.KeyCode then keysDown[input.KeyCode] = nil end
    end)
    Freecam.Conns.render = Services.RunService.RenderStepped:Connect(function(dt)
        if not Freecam.Enabled then return end
        local cam2 = workspace.CurrentCamera
        if cam2.CameraType ~= Enum.CameraType.Scriptable then
            cam2.CameraType = Enum.CameraType.Scriptable
        end
        local char = LocalPlayer.Character
        if char then
            local hum = char:FindFirstChildOfClass("Humanoid")
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if hum then hum.WalkSpeed = 0; hum.JumpPower = 0; hum.JumpHeight = 0 end
            if hrp then hrp.Anchored = true end
        end
        if not Freecam.MouseUnlocked then
            uis.MouseBehavior = Enum.MouseBehavior.LockCenter
            local delta = uis:GetMouseDelta()
            yaw   = yaw   - delta.X * sensitivity
            pitch = math.clamp(pitch - delta.Y * sensitivity, -math.rad(89), math.rad(89))
        end
        local rotation = CFrame.Angles(0, yaw, 0) * CFrame.Angles(pitch, 0, 0)
        local moveSpeed = Freecam.Speed * 60 * dt
        if keysDown[Enum.KeyCode.LeftShift] then moveSpeed = moveSpeed * 3 end
        local forwardDir = (CFrame.Angles(0, yaw, 0) * CFrame.new(0, 0, -1)).Position
        local rightDir   = (CFrame.Angles(0, yaw, 0) * CFrame.new(1, 0, 0)).Position
        local move = Vector3.zero
        if keysDown[Enum.KeyCode.W] then move = move + forwardDir end
        if keysDown[Enum.KeyCode.S] then move = move - forwardDir end
        if keysDown[Enum.KeyCode.D] then move = move + rightDir end
        if keysDown[Enum.KeyCode.A] then move = move - rightDir end
        if keysDown[Enum.KeyCode.E] or keysDown[Enum.KeyCode.Space] then move = move + Vector3.new(0,1,0) end
        if keysDown[Enum.KeyCode.Q] then move = move - Vector3.new(0,1,0) end
        local pos = cam2.CFrame.Position
        if move.Magnitude > 0 then pos = pos + move.Unit * moveSpeed end
        cam2.CFrame = CFrame.new(pos) * rotation
    end)
    Freecam.Conns.charAdded = LocalPlayer.CharacterAdded:Connect(function()
        task.wait(0.3)
        if Freecam.Enabled then Freecam.FreezeCharacter() end
    end)
    uis.MouseIconEnabled = false
    Utils.Alert("Freecam", "video",
        "ON\n• Geser mouse = look around\n• Right-click = unlock/lock mouse\n• WASD = move, Q/E = down/up\n• Space = up, Shift = fast\n• Karakter di-freeze otomatis", 5)
end

function Freecam.Disable()
    if not Freecam.Enabled then return end
    Freecam.Enabled       = false
    Freecam.MouseUnlocked = false
    Utils.DisconnectAll(Freecam.Conns)
    local cam = workspace.CurrentCamera
    local uis = Services.UserInputService
    Freecam.UnfreezeCharacter()
    cam.CameraType       = Freecam.Original.CameraType or Enum.CameraType.Custom
    uis.MouseBehavior    = Freecam.Original.MouseBehavior or Enum.MouseBehavior.Default
    uis.MouseIconEnabled = true
    if Freecam.Original.CameraSubject then
        cam.CameraSubject = Freecam.Original.CameraSubject
    elseif LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        cam.CameraSubject = LocalPlayer.Character.Humanoid
    end
    Freecam.Original = {}
    Utils.Alert("Freecam", "video-off", "OFF — Character & camera restored", 2)
end

function Freecam.Toggle(state)
    if state then Freecam.Enable() else Freecam.Disable() end
end


