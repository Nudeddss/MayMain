local Spectate = {
    Enabled = false,
    Target  = nil,
    Conns   = {},
    OriginalSubject = nil,
}

function Spectate.StartOn(playerName)
    if not playerName or playerName == "" then
        Utils.Alert("Spectate", "eye-off", "Pilih player dulu!", 2); return false
    end
    local target = Services.Players:FindFirstChild(playerName)
    if not target then Utils.Alert("Spectate", "eye-off", "Player tidak ditemukan!", 2); return false end
    if target == LocalPlayer then Utils.Alert("Spectate", "eye-off", "Tidak bisa spectate diri sendiri!", 2); return false end
    if not target.Character then
        Utils.Alert("Spectate", "eye", "Menunggu karakter " .. playerName .. "...", 2)
        local waitStart = tick()
        while not target.Character do
            task.wait(0.1)
            if tick() - waitStart > 10 or not target.Parent then
                Utils.Alert("Spectate", "eye-off", "Timeout!", 2); return false
            end
        end
    end
    local char = target.Character
    local hum  = char:FindFirstChildOfClass("Humanoid")
    if not hum then Utils.Alert("Spectate", "eye-off", "Humanoid not found!", 2); return false end
    Spectate.Stop()
    Spectate.Enabled = true
    Spectate.Target  = target
    Spectate.OriginalSubject = workspace.CurrentCamera.CameraSubject
    workspace.CurrentCamera.CameraSubject = hum
    Spectate.Conns.charAdded = target.CharacterAdded:Connect(function(newChar)
        task.wait(0.5)
        if Spectate.Enabled and Spectate.Target == target then
            local newHum = newChar:FindFirstChildOfClass("Humanoid")
            if newHum then workspace.CurrentCamera.CameraSubject = newHum end
        end
    end)
    Spectate.Conns.playerLeaving = Services.Players.PlayerRemoving:Connect(function(plr)
        if plr == target and Spectate.Enabled then
            Spectate.Stop()
            Utils.Alert("Spectate", "eye-off", target.Name .. " left the game!", 3)
        end
    end)
    Spectate.Conns.localCharAdded = LocalPlayer.CharacterAdded:Connect(function()
        task.wait(0.5)
        if Spectate.Enabled and Spectate.Target then
            local tc = Spectate.Target.Character
            if tc then
                local th = tc:FindFirstChildOfClass("Humanoid")
                if th then workspace.CurrentCamera.CameraSubject = th end
            end
        end
    end)
    Utils.Alert("Spectate", "eye", "Spectating: " .. target.Name, 3)
    return true
end

function Spectate.Stop()
    if not Spectate.Enabled then return end
    Spectate.Enabled = false; Spectate.Target = nil
    Utils.DisconnectAll(Spectate.Conns)
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        workspace.CurrentCamera.CameraSubject = LocalPlayer.Character.Humanoid
    elseif Spectate.OriginalSubject then
        workspace.CurrentCamera.CameraSubject = Spectate.OriginalSubject
    end
    Spectate.OriginalSubject = nil
    Utils.Alert("Spectate", "eye-off", "Stopped spectating", 2)
end


