local AutoStocker = {
    Enabled           = false,
    _isSprinting      = false,
    _lastRestockTime  = 0,
    _RESTOCK_INTERVAL = 600,
    _thread           = nil,
}

-- ---- internal helpers (all prefixed with _ or local) ----

local function _as_getCharacter()
    local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local hrp = character:FindFirstChild("HumanoidRootPart") or character:WaitForChild("HumanoidRootPart", 5)
    local humanoid = character:FindFirstChildOfClass("Humanoid") or character:WaitForChild("Humanoid", 5)
    if not hrp or not humanoid then return nil, nil, nil end
    return character, hrp, humanoid
end

local function _as_checkAlive()
    local character = LocalPlayer.Character
    if not character then return false end
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid or humanoid.Health <= 0 then return false end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp or not hrp.Parent then return false end
    return true
end

function AutoStocker._startSprint()
    if AutoStocker._isSprinting then return end
    AutoStocker._isSprinting = true
    pcall(function()
        Services.VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.LeftShift, false, game)
    end)
end

function AutoStocker._stopSprint()
    if not AutoStocker._isSprinting then return end
    AutoStocker._isSprinting = false
    pcall(function()
        Services.VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.LeftShift, false, game)
    end)
end

local function _as_fireNearestProximity(maxDistance)
    maxDistance = maxDistance or 15
    local _, hrp = _as_getCharacter()
    if not hrp then return false end
    local nearestPrompt, nearestDistance = nil, maxDistance
    for _, descendant in ipairs(workspace:GetDescendants()) do
        if descendant:IsA("ProximityPrompt") and descendant.Enabled then
            local promptParent = descendant.Parent
            if promptParent then
                local position
                if promptParent:IsA("BasePart") then
                    position = promptParent.Position
                elseif promptParent:IsA("Model") then
                    local pp = promptParent.PrimaryPart or promptParent:FindFirstChildWhichIsA("BasePart")
                    if pp then position = pp.Position end
                elseif promptParent:IsA("Attachment") then
                    position = promptParent.WorldPosition
                end
                if position then
                    local distance = (hrp.Position - position).Magnitude
                    if distance < nearestDistance then
                        nearestDistance = distance; nearestPrompt = descendant
                    end
                end
            end
        end
    end
    if nearestPrompt then fireproximityprompt(nearestPrompt); return true end
    return false
end

local function _as_moveWithPathfinding(targetPosition, timeout)
    timeout = timeout or 15
    if not _as_checkAlive() then return false end
    local character, hrp, humanoid = _as_getCharacter()
    if not character or not hrp or not humanoid then return false end
    local targetPos = typeof(targetPosition) == "CFrame" and targetPosition.Position or targetPosition
    local path = Services.PathfindingService:CreatePath({
        AgentRadius = 2, AgentHeight = 5, AgentCanJump = true,
        AgentCanClimb = false, WaypointSpacing = 4,
    })
    local success = pcall(function() path:ComputeAsync(hrp.Position, targetPos) end)
    if not success or path.Status ~= Enum.PathStatus.Success then return false end
    local waypoints = path:GetWaypoints()
    AutoStocker._startSprint()
    for _, waypoint in ipairs(waypoints) do
        if not _as_checkAlive() or not AutoStocker.Enabled then AutoStocker._stopSprint(); return false end
        humanoid:MoveTo(waypoint.Position)
        if waypoint.Action == Enum.PathWaypointAction.Jump then
            humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
        end
        local startTime = tick(); local reached = false
        local conn; conn = humanoid.MoveToFinished:Connect(function() reached = true; if conn then conn:Disconnect() end end)
        while not reached and (tick() - startTime) < 5 do
            if not _as_checkAlive() or not AutoStocker.Enabled then if conn then conn:Disconnect() end; AutoStocker._stopSprint(); return false end
            local _, cHrp = _as_getCharacter()
            if cHrp and (cHrp.Position - waypoint.Position).Magnitude < 3 then reached = true; break end
            task.wait(0.1)
        end
        if conn then conn:Disconnect() end
        if not reached then AutoStocker._stopSprint(); return false end
    end
    return true
end

local function _as_hasReachedPosition(targetPos, threshold)
    threshold = threshold or 4
    local _, hrp = _as_getCharacter()
    if not hrp then return false end
    return (hrp.Position - targetPos).Magnitude < threshold
end

local function _as_moveOnce(targetPosition, timeout)
    timeout = timeout or 10
    if not _as_checkAlive() then return false end
    local character, hrp, humanoid = _as_getCharacter()
    if not character or not hrp or not humanoid then return false end
    local targetPos = typeof(targetPosition) == "CFrame" and targetPosition.Position or targetPosition
    AutoStocker._startSprint()
    humanoid:MoveTo(targetPos)
    local startTime = tick(); local reached = false
    local conn; conn = humanoid.MoveToFinished:Connect(function() reached = true; if conn then conn:Disconnect() end end)
    local lastReapply = startTime
    while not reached and (tick() - startTime) < timeout do
        if not _as_checkAlive() or not AutoStocker.Enabled then if conn then conn:Disconnect() end; AutoStocker._stopSprint(); return false end
        local _, cHrp = _as_getCharacter()
        if cHrp and (cHrp.Position - targetPos).Magnitude < 4 then reached = true; break end
        if (tick() - lastReapply) >= 1 then humanoid:MoveTo(targetPos); lastReapply = tick() end
        task.wait(0.1)
    end
    if conn then conn:Disconnect() end
    return reached
end

local function _as_moveToPosition(targetPosition, timeout, maxRetries)
    timeout = timeout or 10; maxRetries = maxRetries or 5
    local targetPos = typeof(targetPosition) == "CFrame" and targetPosition.Position or targetPosition
    for attempt = 1, maxRetries do
        if not _as_checkAlive() or not AutoStocker.Enabled then return false end
        if _as_hasReachedPosition(targetPos, 4) then return true end
        _as_moveOnce(targetPos, timeout)
        if not _as_checkAlive() or not AutoStocker.Enabled then return false end
        if _as_hasReachedPosition(targetPos, 4) then return true end
        task.wait(0.2)
    end
    return _as_hasReachedPosition(targetPos, 5)
end

local function _as_hasJob(jobName)
    return LocalPlayer:GetAttribute("Job") == jobName
end

local function _as_waitForJob(jobName, timeout)
    timeout = timeout or 10; local startTime = tick()
    while (tick() - startTime) < timeout do
        if _as_hasJob(jobName) then return true end
        if not _as_checkAlive() then return false end
        task.wait(0.3)
    end
    return _as_hasJob(jobName)
end

local function _as_tryJoinJob(jobPost, jobName, maxAttempts)
    maxAttempts = maxAttempts or 3
    for attempt = 1, maxAttempts do
        if not _as_checkAlive() or not AutoStocker.Enabled then return false end
        if _as_hasJob(jobName) then return true end
        local reached = _as_moveWithPathfinding(jobPost, 15)
        if not reached then _as_moveToPosition(jobPost, 10, 3) end
        if not _as_checkAlive() or not AutoStocker.Enabled then return false end
        AutoStocker._stopSprint(); task.wait(0.5)
        _as_fireNearestProximity(10); task.wait(0.5)
        if _as_waitForJob(jobName, 5) then return true end
        _as_fireNearestProximity(10); task.wait(0.5)
        if _as_waitForJob(jobName, 3) then return true end
    end
    return _as_hasJob(jobName)
end

local function _as_getShelfStockerLevel()
    local success, result = pcall(function()
        local pg = LocalPlayer:FindFirstChild("PlayerGui"); if not pg then return 0 end
        local skills = pg:FindFirstChild("Skills"); if not skills then return 0 end
        local sh = skills:FindFirstChild("SkillsHolder"); if not sh then return 0 end
        local sf = sh:FindFirstChild("SkillsScrollingFrame"); if not sf then return 0 end
        for _, child in ipairs(sf:GetChildren()) do
            local st = child:FindFirstChild("SkillTitle")
            if st and st:IsA("TextLabel") and string.find(st.Text, "Shelf Stocker") then
                local level = string.match(st.Text, "Shelf Stocker:%s*(%d+)")
                if level then return tonumber(level) end
            end
        end
        return 0
    end)
    return success and result or 0
end

local function _as_getMaxBoxCount()
    local level = _as_getShelfStockerLevel()
    if level >= 80 then return 6
    elseif level >= 60 then return 5
    elseif level >= 40 then return 4
    elseif level >= 25 then return 3
    elseif level >= 15 then return 2
    else return 1 end
end

local function _as_countBoxes()
    local count = 0
    local character = LocalPlayer.Character; if not character then return 0 end
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    for _, item in ipairs(character:GetChildren()) do
        if item:IsA("Tool") and (string.find(string.lower(item.Name), "box") or string.find(string.lower(item.Name), "stock")) then count = count + 1 end
    end
    if backpack then
        for _, item in ipairs(backpack:GetChildren()) do
            if item:IsA("Tool") and (string.find(string.lower(item.Name), "box") or string.find(string.lower(item.Name), "stock")) then count = count + 1 end
        end
    end
    return count
end

local function _as_hasAvailableShelf(shelvesFolder)
    for _, shelf in ipairs(shelvesFolder:GetChildren()) do
        if shelf:FindFirstChild("Attachment", true) and shelf:FindFirstChild("Attachment", true):IsA("Attachment") then return true end
    end
    return false
end

local function _as_getNextShelf(shelvesFolder)
    for _, shelf in ipairs(shelvesFolder:GetChildren()) do
        local att = shelf:FindFirstChild("Attachment", true)
        if att and att:IsA("Attachment") then return shelf, att end
    end
    return nil, nil
end

local function _as_getCategory(z)
    if z >= 169 and z <= 171 then return 1
    elseif z >= 180 and z <= 188 then return 2
    else return 3 end
end

local function _as_restockGoldenBox()
    if not _as_checkAlive() or not AutoStocker.Enabled then return false end
    local waypoints = {
        Vector3.new(160.508, 255.315, 213),
        Vector3.new(160.449, 255.290, 224),
        Vector3.new(133.669, 255.205, 236.713),
        Vector3.new(133.678, 237.292, 207.711),
        Vector3.new(118.078, 237.459, 209.779),
    }
    for _, wp in ipairs(waypoints) do
        _as_moveToPosition(wp, 5, 3)
        if not _as_checkAlive() or not AutoStocker.Enabled then return false end
    end
    AutoStocker._stopSprint(); task.wait(0.3)
    _as_fireNearestProximity(15); task.wait(0.5)
    if not _as_checkAlive() or not AutoStocker.Enabled then return false end
    local returnWaypoints = {
        Vector3.new(133.678, 237.292, 207.711),
        Vector3.new(133.669, 255.205, 236.713),
        Vector3.new(160.449, 255.290, 224),
        Vector3.new(160.508, 255.315, 213),
    }
    for _, wp in ipairs(returnWaypoints) do
        _as_moveToPosition(wp, 5, 3)
        if not _as_checkAlive() or not AutoStocker.Enabled then return false end
    end
    AutoStocker._lastRestockTime = tick()
    return true
end
local function _as_pickupBoxes(StartPost)
    local maxBoxes = _as_getMaxBoxCount()
    local currentBoxes = _as_countBoxes()
    _as_moveToPosition(StartPost, 5, 3)
    if not _as_checkAlive() or not AutoStocker.Enabled then return false end
    AutoStocker._stopSprint()
    local attempts, maxAttempts = 0, maxBoxes * 3
    while currentBoxes < maxBoxes + 1 and attempts < maxAttempts do
        if not _as_checkAlive() or not AutoStocker.Enabled then return false end
        local beforeCount = _as_countBoxes()
        task.wait(0.2); _as_fireNearestProximity(15); task.wait(0.3)
        local afterCount = _as_countBoxes()
        if afterCount == beforeCount then break end
        currentBoxes = afterCount; attempts = attempts + 1
    end
    return currentBoxes > 0
end

